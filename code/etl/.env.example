# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.
#
# On the production ETL host this file lives OUTSIDE the repo, owned by the
# dedicated ETL OS user with perms 600, and is loaded by the systemd service at
# runtime (see build-plan.md "Secrets management").

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=garnishonline.myshopify.com
SHOPIFY_API_VERSION=2026-04
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Production Layer 1 scopes (read-only, least privilege). The three additions over
# the POC (read_all_orders, read_customers, read_inventory) are DECIDED — see
# build-plan.md Prerequisites. Update these in the Shopify app config (create
# version + release), then re-run oauth_install.py to mint a matching token.
SHOPIFY_SCOPES=read_orders,read_products,read_all_orders,read_customers,read_inventory

# Local OAuth callback (must match the redirect URL configured in the Shopify app)
SHOPIFY_REDIRECT_URI=http://localhost:3000/callback

# Filled in automatically by oauth_install.py after a successful install
SHOPIFY_ACCESS_TOKEN=

# --- Exasol (production instance — Dom's existing DWH host) ---
EXASOL_DSN=your-exasol-host:8563
# Dedicated least-privilege ETL user owning SHOPIFY_STG + SHOPIFY_DWH — NOT SYS.
EXASOL_USER=etl_shopify
EXASOL_PASSWORD=your_password_here
EXASOL_STG_SCHEMA=SHOPIFY_STG
EXASOL_DWH_SCHEMA=SHOPIFY_DWH

# Secure by default on production (real cert over an encrypted connection).
# Set these to false only for a host without a trusted cert (the POC box did).
EXASOL_ENCRYPTION=true
EXASOL_CERTIFICATE_VALIDATION=true

# --- Run settings ---
LOG_LEVEL=INFO
