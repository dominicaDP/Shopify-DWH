# Copy this file to .env and fill in real values.
# .env is gitignored — never commit secrets.

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=dressyourtech.myshopify.com
SHOPIFY_API_VERSION=2026-04
SHOPIFY_CLIENT_ID=your_client_id_here
SHOPIFY_CLIENT_SECRET=your_client_secret_here

# Scopes the POC needs (read-only, least privilege)
SHOPIFY_SCOPES=read_orders,read_products

# Local OAuth callback (must match the redirect URL configured in the Shopify app)
SHOPIFY_REDIRECT_URI=http://localhost:3000/callback

# Filled in automatically by oauth_install.py after first successful install
SHOPIFY_ACCESS_TOKEN=

# --- Exasol (filled in once Exasol is running) ---
EXASOL_DSN=localhost:8563
EXASOL_USER=sys
EXASOL_PASSWORD=exasol
EXASOL_SCHEMA=SHOPIFY_STG
